{
  "name": "@ecauth/auth-js",
  "version": "0.1.1",
  "description": "EcAuth client-side authentication library (WebAuthn, PKCE)",
  "license": "LGPL-2.1-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/EcAuth/ecauth-auth-js"
  },
  "type": "module",
  "main": "dist/ecauth-auth.umd.js",
  "module": "dist/ecauth-auth.esm.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/ecauth-auth.esm.js",
      "require": "./dist/ecauth-auth.umd.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "packageManager": "pnpm@10.30.3",
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  },
  "devDependencies": {
    "typescript": "^5.0",
    "vite": "^6.0",
    "vite-plugin-dts": "^4.0",
    "vitest": "^3.0",
    "jsdom": "^26.0"
  }
}
